{
  "name": "devforge",
  "version": "1.0.0",
  "private": true,
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "smoke": "bun run tests/smoke-test.ts",
    "bench": "bun run scripts/bench.ts",
    "build": "bun run build:core && bun run build:cli",
    "build:core": "cd packages/core && bun build ./src/index.ts --outdir ./dist --target node",
    "build:cli": "cd packages/cli && bun build ./src/bin.ts --outdir ./dist --target node",
    "publish:all": "npm run publish:core && npm run publish:cli",
    "publish:core": "cd packages/core && npm publish --access public",
    "publish:cli": "npm pkg set dependencies.@ahmadubaidillah/core=\"^$(node -p \"require('./packages/core/package.json').version\")\" -w @ahmadubaidillah/cli && cd packages/cli && npm publish --access public"
  },
  "workspaces": [
    "packages/*",
    "templates/*"
  ],
  "devDependencies": {
    "@hono/swagger-ui": "^0.6.0",
    "@hono/zod-openapi": "^1.2.2",
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "@types/fs-extra": "^11.0.4",
    "@types/glob": "^9.0.0",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "better-auth": "^1.5.3",
    "bullmq": "^5.70.2",
    "drizzle-orm": "^0.45.1",
    "eslint": "latest",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "hono": "^4.12.5",
    "ioredis": "^5.10.0",
    "lucide-react": "^0.577.0",
    "meilisearch": "^0.55.0",
    "posthog-node": "^5.28.0",
    "prettier": "latest",
    "recharts": "^3.7.0",
    "stripe": "^20.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.3",
    "chalk": "^5.6.2",
    "zod": "3.22.4"
  }
}
